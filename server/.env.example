# PostgreSQL connection string (Neon pooled, or local) — used by the running app
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Direct (non-pooled) connection — used by Prisma migrations.
# On Neon this is the same URL WITHOUT "-pooler" in the host.
# Locally you can set it to the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign admin JWTs — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-string"

# Comma-separated list of allowed frontend origins
CORS_ORIGIN="http://localhost:5173"

# Server port
PORT=4000

# Seed admin credentials (used by `npm run db:seed`)
ADMIN_EMAIL="admin@acowale.com"
ADMIN_PASSWORD="ChangeMe123!"

# Logging: debug | info | warn | error
LOG_LEVEL="info"
